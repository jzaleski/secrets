#!/usr/bin/env bash

set -e;

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Check if secrets are decrypted and up to date.

Options:
  -h, --help    Show this help message and exit

Environment:
  None

Examples:
  $(basename "$0")
  $(basename "$0") --help

Exit codes:
  0   Secrets are decrypted and up to date
  1   Secrets are missing or out of date
EOF
}

if [[ $# -gt 0 ]]; then
  case "$1" in
    -h|--help)
      usage;
      exit 0;
      ;;
    *)
      echo "Unknown option: $1" >&2;
      usage >&2;
      exit 1;
      ;;
  esac
fi

if [ ! -d "secrets" ]; then
  echo "Error: missing \"secrets\" directory." >&2;
  echo "Run \"decrypt-secrets\" to decrypt secrets, or \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

if [ ! -f "secrets/secrets.version" ]; then
  echo "Error: \"secrets\" directory is incomplete or out of date." >&2;
  echo "Run \"decrypt-secrets\" to fix this, or \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

encrypted_version=$(cat secrets.lock);
decrypted_version=$(cat secrets/secrets.version);

if test "$decrypted_version" -lt "$encrypted_version"; then
  echo "Error: \"secrets\" is out of date (need version $encrypted_version, have $decrypted_version)." >&2;
  echo "Run \"decrypt-secrets\" to update, or \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi
