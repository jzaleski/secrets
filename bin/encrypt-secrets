#!/usr/bin/env bash

set -e;

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Encrypt the secrets directory into a GPG-encrypted archive.

Options:
  -h, --help    Show this help message and exit

Environment:
  SECRETS_PASSPHRASE    Required. The passphrase for encrypting secrets
  SECRETS_CIPHER_ALGO   Optional. Cipher algorithm (default: AES256)

Examples:
  export SECRETS_PASSPHRASE="your-passphrase"
  $(basename "$0")
  $(basename "$0") --help

Exit codes:
  0   Secrets encrypted successfully
  1   Error: missing secrets directory, passphrase, or GPG
EOF
}

if [[ $# -gt 0 ]]; then
  case "$1" in
    -h|--help)
      usage;
      exit 0;
      ;;
    *)
      echo "Unknown option: $1" >&2;
      usage >&2;
      exit 1;
      ;;
  esac
fi

gpg_cmd=$(which gpg 2> /dev/null || echo -n);
if [ -z "$gpg_cmd" ]; then
  echo "Error: \"gpg\" command not found." >&2;
  echo "Install it with: brew install gpg" >&2;
  echo "Run \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

if [ ! -d "secrets" ]; then
  echo "Error: \"secrets\" directory not found." >&2;
  echo "Run \"decrypt-secrets\" first to create it, or \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

if [ ! -e "secrets/secrets.version" ]; then
  echo 0 > secrets/secrets.version;
fi

expr $(cat secrets/secrets.version) + 1 > secrets/secrets.version;
cp secrets/secrets.version secrets.lock;

tar c secrets | gzip > secrets.tar.gz;
rm -f secrets.tar.gz.gpg;

if [ -z "${SECRETS_PASSPHRASE}" ]; then
  echo "Error: \"SECRETS_PASSPHRASE\" environment variable not set." >&2;
  echo "Set it before running, e.g.: export SECRETS_PASSPHRASE=\"your-passphrase\"" >&2;
  echo "Run \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

${gpg_cmd} \
  --quiet \
  --batch \
  --cipher-algo ${SECRETS_CIPHER_ALGO:-"AES256"} \
  --passphrase "${SECRETS_PASSPHRASE}" \
  --symmetric secrets.tar.gz;

rm -f secrets.tar.gz;
