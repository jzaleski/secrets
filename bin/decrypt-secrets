#!/usr/bin/env bash

set -e;

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Decrypt the secrets directory from the encrypted archive.

Options:
  -h, --help    Show this help message and exit

Environment:
  SECRETS_PASSPHRASE    Required. The passphrase for decrypting secrets
  SECRETS_CIPHER_ALGO   Optional. Cipher algorithm (default: AES256)

Examples:
  export SECRETS_PASSPHRASE="your-passphrase"
  $(basename "$0")
  $(basename "$0") --help

Exit codes:
  0   Secrets decrypted successfully
  1   Error: missing encrypted archive, passphrase, or GPG
EOF
}

if [[ $# -gt 0 ]]; then
  case "$1" in
    -h|--help)
      usage;
      exit 0;
      ;;
    *)
      echo "Unknown option: $1" >&2;
      usage >&2;
      exit 1;
      ;;
  esac
fi

gpg_cmd=$(which gpg 2> /dev/null || echo -n);
if [ -z "$gpg_cmd" ]; then
  echo "Error: \"gpg\" command not found." >&2;
  echo "Install it with: brew install gpg" >&2;
  echo "Run \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

if [ ! -f "secrets.tar.gz.gpg" ]; then
  echo "Error: encrypted secrets file \"secrets.tar.gz.gpg\" not found." >&2;
  echo "Run \"encrypt-secrets\" first to create it, or \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

if [ -z "${SECRETS_PASSPHRASE}" ]; then
  echo "Error: \"SECRETS_PASSPHRASE\" environment variable not set." >&2;
  echo "Set it before running, e.g.: export SECRETS_PASSPHRASE=\"your-passphrase\"" >&2;
  echo "Run \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

${gpg_cmd} \
  --quiet \
  --batch \
  --cipher-algo ${SECRETS_CIPHER_ALGO:-"AES256"} \
  --passphrase "${SECRETS_PASSPHRASE}" \
  secrets.tar.gz.gpg;

rm -rf secrets;
cat secrets.tar.gz | gunzip | tar x;
rm -f secrets.tar.gz;
