#!/usr/bin/env bash

set -e;

usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Initialize the secrets directory structure for encrypt-secrets.

Options:
  -h, --help    Show this help message and exit

Examples:
  $(basename "$0")
  $(basename "$0") --help

Exit codes:
  0   Secrets directory initialized successfully
  1   Error: secrets directory already exists
EOF
}

if [[ $# -gt 0 ]]; then
  case "$1" in
    -h|--help)
      usage;
      exit 0;
      ;;
    *)
      echo "Unknown option: $1" >&2;
      usage >&2;
      exit 1;
      ;;
  esac
fi

if [ -d "secrets" ]; then
  echo "Error: \"secrets\" directory already exists." >&2;
  echo "Remove it first if you want to reinitialize: rm -rf secrets" >&2;
  echo "Run \"$(basename "$0") --help\" for more information." >&2;
  exit 1;
fi

mkdir -p secrets;
echo 0 > secrets/secrets.version;
echo "Created secrets directory with version 0";
echo "Add your secret files to the secrets/ directory";
echo "Then run: SECRETS_PASSPHRASE=\"your-passphrase\" encrypt-secrets"